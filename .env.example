# WaitingTheLongest - Environment Configuration
# Copy to .env and fill in real values
# DO NOT commit .env file to version control

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=waitingthelongest
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=GENERATE_A_32_CHAR_RANDOM_STRING_HERE
REDIS_DB=0

# Authentication
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
JWT_ISSUER=waitingthelongest.com
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30
BCRYPT_COST=12

# External API Keys
# NOTE: THERE IS NO PETFINDER API. Do not add Petfinder keys here.

# RescueGroups API
RESCUEGROUPS_API_KEY=

# TheDogAPI (support up to 4 keys for rate limit distribution)
THEDOGAPI_KEY_1=
THEDOGAPI_KEY_2=
THEDOGAPI_KEY_3=
THEDOGAPI_KEY_4=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://waitingthelongest.com/auth/google/callback

# Email Service (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@waitingthelongest.com
FROM_NAME=WaitingTheLongest

# Domain & SSL Configuration
DOMAIN=waitingthelongest.com
SSL_EMAIL=admin@waitingthelongest.com
NODE_ENV=development

# Amazon Associates
AMAZON_ASSOCIATE_TAG=waitingthelon-20

# Application Settings
LOG_LEVEL=info
DEBUG_MODE=false
ENABLE_CORS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=3000
SESSION_TIMEOUT_MINUTES=1440
