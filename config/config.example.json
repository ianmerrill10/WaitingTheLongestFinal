{
    "_comment": "WaitingTheLongest.com Configuration Template",
    "_version": "1.0.0",
    "_instructions": "Copy this file to config.json and update values for your environment",

    "server": {
        "_comment": "HTTP server configuration",
        "host": "0.0.0.0",
        "port": 8080,
        "threads": 4,
        "enable_ssl": false,
        "ssl_cert_path": "/path/to/cert.pem",
        "ssl_key_path": "/path/to/key.pem",
        "document_root": "./static",
        "upload_path": "./uploads",
        "max_upload_size_mb": 10,
        "session_timeout_seconds": 3600,
        "enable_gzip": true,
        "enable_brotli": false,
        "log_level": "INFO"
    },

    "database": {
        "_comment": "PostgreSQL database configuration",
        "host": "localhost",
        "port": 5432,
        "name": "waitingthelongest",
        "user": "wtl_user",
        "password": "CHANGE_ME_IN_PRODUCTION",
        "pool_size": 10,
        "connection_timeout_seconds": 30,
        "idle_timeout_seconds": 600,
        "max_retries": 3,
        "retry_delay_ms": 1000,
        "ssl_mode": "prefer",
        "application_name": "WaitingTheLongest"
    },

    "redis": {
        "_comment": "Redis cache configuration (optional)",
        "enabled": false,
        "host": "localhost",
        "port": 6379,
        "password": "",
        "database": 0,
        "pool_size": 5,
        "connection_timeout_seconds": 5,
        "key_prefix": "wtl:"
    },

    "auth": {
        "_comment": "Authentication and security configuration",
        "jwt_secret": "CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS",
        "jwt_issuer": "waitingthelongest.com",
        "jwt_audience": "waitingthelongest-api",
        "access_token_expiry_minutes": 15,
        "refresh_token_expiry_days": 7,
        "password_min_length": 8,
        "password_require_uppercase": true,
        "password_require_lowercase": true,
        "password_require_number": true,
        "password_require_special": false,
        "max_login_attempts": 5,
        "lockout_duration_minutes": 15,
        "bcrypt_cost": 12,
        "session_cookie_name": "wtl_session",
        "session_cookie_secure": true,
        "session_cookie_httponly": true,
        "session_cookie_samesite": "Strict"
    },

    "websocket": {
        "_comment": "WebSocket configuration for real-time updates",
        "enabled": true,
        "path": "/ws",
        "ping_interval_seconds": 30,
        "pong_timeout_seconds": 10,
        "max_connections_per_ip": 10,
        "message_rate_limit": 100,
        "message_rate_window_seconds": 60
    },

    "api": {
        "_comment": "API configuration",
        "base_path": "/api",
        "version": "v1",
        "rate_limit_enabled": true,
        "rate_limit_requests": 100,
        "rate_limit_window_seconds": 60,
        "cors_enabled": true,
        "cors_allowed_origins": ["https://waitingthelongest.com", "http://localhost:3000"],
        "cors_allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
        "cors_allowed_headers": ["Content-Type", "Authorization", "X-Request-ID"],
        "cors_max_age_seconds": 86400,
        "default_page_size": 20,
        "max_page_size": 100
    },

    "external_apis": {
        "_comment": "External API integrations",
        "_WARNING": "THERE IS NO PETFINDER API. Do not add a petfinder section here.",
        "rescuegroups": {
            "enabled": true,
            "api_key": "YOUR_RESCUEGROUPS_API_KEY",
            "api_url": "https://api.rescuegroups.org/v5",
            "sync_interval_minutes": 30,
            "timeout_seconds": 30,
            "max_retries": 3
        }
    },

    "debug": {
        "_comment": "Debug and error handling configuration",
        "enabled": true,
        "log_to_console": true,
        "log_to_file": true,
        "log_file_path": "./logs/wtl.log",
        "log_rotation_size_mb": 100,
        "log_retention_days": 30,
        "capture_stack_traces": true,
        "max_errors_in_memory": 1000,
        "error_export_path": "./logs/errors",
        "health_check_interval_seconds": 60,
        "enable_performance_logging": false,
        "slow_query_threshold_ms": 1000
    },

    "self_healing": {
        "_comment": "Self-healing and circuit breaker configuration",
        "enabled": true,
        "circuit_breaker_threshold": 5,
        "circuit_breaker_timeout_seconds": 60,
        "retry_max_attempts": 3,
        "retry_base_delay_ms": 100,
        "retry_max_delay_ms": 5000,
        "retry_multiplier": 2.0,
        "connection_pool_reset_threshold": 10,
        "auto_reconnect_enabled": true
    },

    "modules": {
        "_comment": "Optional module configuration",
        "urgency_engine": {
            "enabled": true,
            "critical_threshold_hours": 24,
            "high_threshold_hours": 72,
            "medium_threshold_hours": 168,
            "update_interval_seconds": 60
        },
        "foster_system": {
            "enabled": true,
            "max_active_placements": 3,
            "application_review_days": 7
        },
        "notifications": {
            "enabled": false,
            "email_provider": "smtp",
            "smtp_host": "smtp.example.com",
            "smtp_port": 587,
            "smtp_user": "",
            "smtp_password": "",
            "from_email": "noreply@waitingthelongest.com",
            "from_name": "WaitingTheLongest"
        }
    },

    "features": {
        "_comment": "Feature flags for enabling/disabling functionality",
        "enable_user_registration": true,
        "enable_foster_applications": true,
        "enable_shelter_admin": true,
        "enable_api_documentation": true,
        "enable_metrics_endpoint": false,
        "enable_admin_panel": true,
        "maintenance_mode": false,
        "maintenance_message": "We're performing scheduled maintenance. Please check back soon."
    },

    "environment": {
        "_comment": "Environment-specific settings",
        "name": "development",
        "is_production": false,
        "debug_mode": true,
        "show_errors": true,
        "timezone": "UTC"
    }
}
