{
    "_comment": "WaitingTheLongest.com External API Aggregator Configuration",
    "_version": "1.0.0",
    "_instructions": "Configure external data sources for aggregating shelter/dog data",

    "global": {
        "_comment": "Global aggregator settings",
        "enabled": true,
        "auto_sync_enabled": true,
        "auto_sync_interval_minutes": 60,
        "max_concurrent_syncs": 2,
        "default_timeout_seconds": 30,
        "default_retry_attempts": 3,
        "default_retry_delay_ms": 1000,
        "default_retry_multiplier": 2.0,
        "log_level": "INFO"
    },

    "rate_limiting": {
        "_comment": "Global rate limiting defaults",
        "enabled": true,
        "default_requests_per_minute": 60,
        "burst_multiplier": 1.5,
        "refill_interval_ms": 100
    },

    "duplicate_detection": {
        "_comment": "Duplicate detection configuration",
        "enabled": true,
        "name_similarity_threshold": 0.85,
        "auto_merge_threshold": 0.95,
        "check_name_shelter": true,
        "check_name_breed_age": true,
        "check_external_id": true,
        "max_candidates_per_sync": 100
    },

    "data_mapping": {
        "_comment": "Data normalization settings",
        "normalize_breeds": true,
        "normalize_sizes": true,
        "normalize_ages": true,
        "normalize_statuses": true,
        "unknown_breed_default": "Mixed Breed",
        "unknown_size_default": "medium",
        "unknown_age_default": "unknown"
    },

    "sources": {
        "_WARNING": "THERE IS NO PETFINDER API. Do not add a petfinder source here.",

        "rescuegroups": {
            "_comment": "RescueGroups.org API v5 configuration",
            "enabled": true,
            "priority": 2,
            "display_name": "RescueGroups.org",
            "api_base_url": "https://api.rescuegroups.org/v5",

            "auth": {
                "type": "api_key",
                "api_key": "YOUR_RESCUEGROUPS_API_KEY",
                "header_name": "Authorization"
            },

            "sync": {
                "interval_hours": 6,
                "page_size": 250,
                "max_pages": 50,
                "incremental_enabled": true,
                "full_sync_interval_hours": 24
            },

            "rate_limit": {
                "requests_per_second": 2,
                "requests_per_minute": 100
            },

            "filters": {
                "species": "Dog",
                "status": "Available",
                "organizations": []
            },

            "field_mappings": {
                "id": "external_id",
                "attributes.name": "name",
                "attributes.breedPrimary": "breed",
                "attributes.breedSecondary": "secondary_breed",
                "attributes.isMixedBreed": "is_mixed",
                "attributes.ageGroup": "age_category",
                "attributes.sex": "gender",
                "attributes.sizeGroup": "size",
                "attributes.coatLength": "coat",
                "attributes.colorDetails": "primary_color",
                "attributes.descriptionText": "description",
                "attributes.pictureThumbnailUrl": "photo_url",
                "attributes.adoptionStatus": "status",
                "attributes.isAltered": "is_spayed_neutered",
                "attributes.isHousetrained": "is_house_trained",
                "attributes.isSpecialNeeds": "has_special_needs",
                "attributes.isCurrentVaccinations": "has_shots",
                "attributes.isKidsOk": "good_with_children",
                "attributes.isDogsOk": "good_with_dogs",
                "attributes.isCatsOk": "good_with_cats",
                "attributes.url": "external_url",
                "attributes.createdDate": "intake_date",
                "relationships.orgs.data[0].id": "shelter_external_id"
            }
        },

        "shelter_direct": {
            "_comment": "Direct shelter feeds configuration",
            "enabled": true,
            "priority": 3,
            "display_name": "Direct Shelter Feeds",

            "sync": {
                "interval_hours": 4,
                "timeout_seconds": 60
            },

            "feeds": [
                {
                    "_comment": "Example feed configuration - modify or remove",
                    "id": "example_shelter_1",
                    "shelter_id": null,
                    "shelter_name": "Example Animal Shelter",
                    "url": "https://example-shelter.com/api/dogs.json",
                    "format": "json",
                    "enabled": false,
                    "auth_type": "none",
                    "auth_value": "",
                    "animals_path": "animals",
                    "field_mappings": {
                        "id": "external_id",
                        "pet_name": "name",
                        "breed": "breed",
                        "age": "age_category",
                        "sex": "gender",
                        "weight": "weight",
                        "bio": "description",
                        "image_url": "photo_url"
                    }
                }
            ]
        }
    },

    "notifications": {
        "_comment": "Notifications for sync events",
        "enabled": false,
        "on_sync_complete": false,
        "on_sync_error": true,
        "on_critical_error": true,
        "email_recipients": [],
        "webhook_url": null
    },

    "health_checks": {
        "_comment": "Health check configuration",
        "enabled": true,
        "interval_minutes": 15,
        "timeout_seconds": 10,
        "consecutive_failures_threshold": 3,
        "auto_disable_on_failure": false
    },

    "metrics": {
        "_comment": "Metrics and monitoring",
        "enabled": true,
        "retention_days": 30,
        "detailed_logging": false,
        "export_format": "json"
    }
}
