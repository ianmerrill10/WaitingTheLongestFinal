{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "threads": 8,
    "enable_ssl": false,
    "enable_gzip": true,
    "enable_brotli": true,
    "log_level": "WARNING",
    "request_timeout_ms": 30000,
    "shutdown_timeout_ms": 30000
  },
  "database": {
    "host": "${DB_HOST}",
    "port": 5432,
    "name": "waitingthelongest",
    "user": "${DB_USER}",
    "password": "${DB_PASSWORD}",
    "pool_size": 20,
    "pool_idle_timeout_ms": 600000,
    "ssl_mode": "require",
    "query_timeout_ms": 30000
  },
  "redis": {
    "enabled": true,
    "host": "${REDIS_HOST}",
    "port": 6379,
    "password": "${REDIS_PASSWORD}",
    "db": 0,
    "pool_size": 10,
    "timeout_ms": 5000,
    "key_prefix": "wtl:"
  },
  "auth": {
    "jwt_secret": "${JWT_SECRET}",
    "jwt_issuer": "${JWT_ISSUER}",
    "jwt_expiration_hours": 24,
    "refresh_token_expiration_days": 30,
    "bcrypt_cost": 12,
    "session_cookie_secure": true,
    "session_cookie_http_only": true,
    "session_cookie_same_site": "Strict",
    "session_timeout_minutes": 1440
  },
  "websocket": {
    "enabled": true,
    "path": "/ws",
    "max_connections": 10000,
    "max_connections_per_ip": 5,
    "message_size_limit_bytes": 65536,
    "heartbeat_interval_ms": 30000,
    "heartbeat_timeout_ms": 60000
  },
  "api": {
    "version": "v1",
    "cors_enabled": true,
    "cors_allowed_origins": [
      "https://waitingthelongest.com",
      "https://www.waitingthelongest.com"
    ],
    "cors_allowed_methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
    "cors_allow_credentials": true,
    "rate_limit_enabled": true,
    "rate_limit_requests": 60,
    "rate_limit_window_seconds": 60,
    "rate_limit_burst": 10
  },
  "debug": {
    "enabled": false,
    "log_to_console": false,
    "log_to_file": true,
    "log_file_path": "/var/log/waitingthelongest/app.log",
    "log_rotation_max_size_mb": 100,
    "log_rotation_max_files": 10
  },
  "environment": {
    "name": "production",
    "is_production": true,
    "debug_mode": false,
    "show_errors": false,
    "show_stack_traces": false
  },
  "external_apis": {
    "_WARNING": "THERE IS NO PETFINDER API. Do not add a petfinder section here.",
    "rescuegroups": {
      "enabled": true,
      "base_url": "https://api.rescuegroupsapi.org/v5",
      "timeout_ms": 10000,
      "retry_attempts": 3,
      "retry_delay_ms": 1000
    },
    "thedogapi": {
      "enabled": true,
      "base_url": "https://api.thedogapi.com/v1",
      "timeout_ms": 10000,
      "retry_attempts": 3,
      "retry_delay_ms": 1000,
      "max_keys": 4
    },
    "google_oauth": {
      "enabled": true,
      "base_url": "https://accounts.google.com",
      "timeout_ms": 10000
    }
  },
  "email": {
    "provider": "sendgrid",
    "from_email": "${FROM_EMAIL}",
    "from_name": "WaitingTheLongest",
    "timeout_ms": 10000,
    "retry_attempts": 3
  },
  "features": {
    "enable_social_login": true,
    "enable_email_notifications": true,
    "enable_pet_alerts": true,
    "enable_analytics": true,
    "enable_admin_dashboard": true
  }
}
